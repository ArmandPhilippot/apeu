{
  "name": "apeu",
  "description": "The code source of my personal website.",
  "version": "2.2.0",
  "license": "MIT",
  "author": {
    "name": "Armand Philippot",
    "email": "git@armand.philippot.eu",
    "url": "https://armand.philippot.eu/"
  },
  "homepage": "https://github.com/ArmandPhilippot/apeu#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:ArmandPhilippot/apeu.git"
  },
  "bugs": {
    "url": "https://github.com/ArmandPhilippot/apeu/issues"
  },
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "astro": "astro",
    "build": "astro check && astro build",
    "build:e2e": "astro build --devOutput",
    "ci:release": "changeset publish",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile",
    "dev": "astro dev",
    "fix": "pnpm run \"/^fix:.*/\"",
    "fix:formatting": "prettier . --write",
    "fix:scripts": "eslint --fix .",
    "fix:styles": "stylelint --fix \"src/**/*.{astro,css,scss}\"",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:formatting": "prettier . --check",
    "lint:scripts": "eslint .",
    "lint:spelling": "cspell \"**\" --no-progress",
    "lint:styles": "stylelint \"src/**/*.{astro,css,scss}\"",
    "lint:types": "astro check",
    "prepare": "husky",
    "preview": "astro preview",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:e2e": "pnpm build:e2e && pnpm test:e2e:run",
    "test:e2e:install": "pnpm exec playwright install chromium",
    "test:e2e:run": "pnpm exec playwright test",
    "test:e2e:ui": "pnpm build:e2e && pnpm exec playwright test --ui",
    "test:unit": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:watch": "vitest watch",
    "knip": "knip"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/compiler-rs": "^0.3.0",
    "@astrojs/markdown-satteri": "^0.3.2",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/node": "^11.0.0",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@nanostores/persistent": "^1.3.4",
    "@pagefind/default-ui": "^1.5.2",
    "@rolldown/pluginutils": "^1.0.1",
    "astro": "^7.0.4",
    "astro-icon": "^1.1.5",
    "is-relative-url": "^4.1.0",
    "mdast-util-to-nlcst": "^7.0.1",
    "modern-normalize": "^3.0.1",
    "nanostores": "^1.4.0",
    "nodemailer": "^9.0.3",
    "pagefind": "^1.5.2",
    "parse-english": "^7.0.0",
    "parse-latin": "^7.0.0",
    "satori-astro": "^0.4.0",
    "satori-html": "^0.3.2",
    "satteri": "^0.9.4",
    "sharp": "^0.35.3",
    "sharp-ico": "^0.1.5",
    "shiki": "^4.3.0",
    "sirv": "^3.0.2",
    "slash": "^5.1.0",
    "tinyglobby": "^0.2.17",
    "ultrahtml": "^1.6.0",
    "vfile": "^6.0.3",
    "vite": "^8.1.2",
    "zod-form-data": "^3.0.2"
  },
  "devDependencies": {
    "@arphi/commitlint-config": "^1.0.9",
    "@arphi/eslint-config": "^2.5.1",
    "@arphi/prettier-config": "^1.0.4",
    "@arphi/stylelint-config": "2.0.0",
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.0",
    "@cspell/dict-fr-fr": "^2.3.2",
    "@csstools/postcss-global-data": "^4.0.0",
    "@e18e/eslint-plugin": "^0.5.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/nlcst": "^2.0.3",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "@types/web-app-manifest": "^1.0.9",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "astro-eslint-parser": "^1.4.0",
    "autoprefixer": "^10.5.2",
    "baseline-browser-mapping": "^2.10.42",
    "cspell": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "husky": "^9.1.7",
    "knip": "^6.23.0",
    "lint-staged": "^17.0.8",
    "postcss-html": "^1.8.1",
    "postcss-preset-env": "^11.3.2",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "schema-dts": "^2.0.0",
    "stylelint": "^17.14.0",
    "stylelint-config-html": "^1.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
