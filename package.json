    "ci:version": "changeset version && pnpm install --no-frozen-lockfile",
    "dev": "astro dev",
    "fix": "pnpm run \"/^fix:.*/\"",
    "fix:formatting": "prettier . --write",
    "fix:scripts": "eslint --fix .",
    "fix:styles": "stylelint --fix \"src/**/*.{astro,css,scss}\"",
